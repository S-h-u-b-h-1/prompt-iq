{
  "manifest_version": 3,
  "name": "PromptIQ",
  "version": "1.0.5",
  "description": "A browser extension that scores your prompt, optimizes it for the specific AI you're using, and explains every change.",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "*://chatgpt.com/*",
    "*://chat.openai.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*",
    "*://www.perplexity.ai/*",
    "*://copilot.microsoft.com/*",
    "*://chat.deepseek.com/*",
    "https://promptiq-theta.vercel.app/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://www.perplexity.ai/*",
        "*://copilot.microsoft.com/*",
        "*://chat.deepseek.com/*"
      ],
      "js": ["src/content/inject.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "store_icon.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "store_icon.png"
    }
  }
}
